{
  "expo": {
    "name": "Maraton",
    "slug": "maraton",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "maraton",
    "description": "YKS hazırlık sürecini takip et: günlük plan, deneme analizi, yanlış defteri.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maraton.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:maraton.app"],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Yanlış soru fotoğrafı eklemek için galeri erişimi gerekli.",
        "NSCameraUsageDescription": "Yanlış soru fotoğrafı çekmek için kamera erişimi gerekli.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Çalışma hatırlatmaları ve streak bildirimleri göndermek için bildirim izni gerekli."
      }
    },
    "android": {
      "package": "com.maraton.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "maraton.app",
              "pathPrefix": "/referral"
            },
            {
              "scheme": "https",
              "host": "maraton.app",
              "pathPrefix": "/friend"
            },
            {
              "scheme": "https",
              "host": "maraton.app",
              "pathPrefix": "/group"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "@sentry/react-native/expo",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.PLACEHOLDER_IOS_CLIENT_ID"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F5A623",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Yanlış soru fotoğrafı eklemek için galeri erişimi gerekli.",
          "cameraPermission": "Yanlış soru fotoğrafı çekmek için kamera erişimi gerekli."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b7c40c1c-f724-4c07-ad36-696ef890ce64"
      }
    },
    "owner": "ahmeterenn",
    "updates": {
      "url": "https://u.expo.dev/b7c40c1c-f724-4c07-ad36-696ef890ce64"
    }
  }
}
